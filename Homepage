.why-item h4 {
font-family: ‘Playfair Display’, serif;
font-size: 1rem; font-weight: 700;
margin-bottom: 0.3rem;
}
.why-item p { font-size: 0.86rem; opacity: 0.55; line-height: 1.6; }

.why-visual {
position: sticky; top: 8rem;
}
.big-quote {
font-family: ‘Playfair Display’, serif;
font-size: clamp(1.8rem, 3.5vw, 3rem);
font-style: italic;
font-weight: 400;
line-height: 1.35;
color: var(–cream);
margin-bottom: 2rem;
}
.big-quote strong { color: var(–gold); font-weight: 700; font-style: normal; }

/* ── TESTIMONIALS ── */
.testimonials-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 1.5rem;
}
.test-card {
border: 1px solid var(–border);
border-radius: 4px;
padding: 2rem;
background: var(–card-bg);
