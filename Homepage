.test-author { display: flex; align-items: center; gap: 0.8rem; }
.author-av {
width: 40px; height: 40px;
border-radius: 50%;
background: linear-gradient(135deg, rgba(201,168,76,0.3), rgba(201,168,76,0.1));
border: 1px solid var(–border);
display: flex; align-items: center; justify-content: center;
font-size: 1rem;
}
.author-name { font-size: 0.88rem; font-weight: 500; }
.author-role { font-size: 0.75rem; opacity: 0.45; margin-top: 0.1rem; }

/* ── CTA ── */
.cta-section {
text-align: center;
background: linear-gradient(135deg, rgba(201,168,76,0.1) 0%, rgba(10,15,30,0) 70%);
border-top: 1px solid var(–border);
border-bottom: 1px solid var(–border);
}
.cta-section h2 { margin-bottom: 1rem; }
.cta-section p { opacity: 0.6; max-width: 500px; margin: 0 auto 2.5rem; line-height: 1.7; }

/* ── FOOTER ── */
footer {
padding: 3rem 6%;
border-top: 1px solid var(–border);
display: flex; align-items: center; justify-content: space-between;
flex-wrap: wrap; gap: 1.5rem;
}
.footer-links { display: flex; gap: 2rem; }
.footer-links a { color: var(–cream); opacity: 0.4; text-decoration: none; font-size: 0.82rem; transition: opacity 0.2s; }
.footer-links a:hover { opacity: 0.8; }
.footer-copy { font-size: 0.8rem; opacity: 0.3; }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
from { opacity: 0; transform: translateY(24px); }
to   { opacity: 1; transform: translateY(0); }
}

.reveal {
opacity: 0; transform: translateY(30px);
transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
.about-grid, .why-grid { grid-template-columns: 1fr; }
.courses-grid, .testimonials-grid { grid-template-columns: 1fr 1fr; }
.why-visual { position: static; }
.hero-stats { gap: 2rem; }
.nav-links { display: none; }
}
@media (max-width: 600px) {
.courses-grid, .testimonials-grid { grid-template-columns: 1fr; }
.hero-stats { flex-wrap: wrap; gap: 1.5rem; }
nav { padding: 1rem 5%; }
}
</style>

